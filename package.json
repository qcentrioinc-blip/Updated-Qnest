{
  "name": "productx",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "npx playwright test",
    "test:safari": "npx playwright test --project=\"Desktop Safari — macOS 1440×900\" --ui",
    "test:chrome": "npx playwright test --project=\"Desktop Chrome — Windows 1440×900\" --ui",
    "test:linux": "npx playwright test --project=\"Desktop Firefox — Windows 1440×900\" --ui",
    "test:e2e:chromium": "npx playwright test --project=\"Desktop Chrome*\"",
    "test:e2e:firefox": "npx playwright test --project=\"Desktop Firefox*\"",
    "test:e2e:webkit": "npx playwright test --project=\"Desktop Safari*\" --project=\"iPad*\" --project=\"iPhone*\"",
    "test:e2e:mobile": "npx playwright test --project=\"iPhone*\" --project=\"Pixel*\" --project=\"Galaxy S*\"",
    "test:e2e:tablet": "npx playwright test --project=\"iPad*\" --project=\"Galaxy Tab*\"",
    "test:e2e:desktop": "npx playwright test --project=\"Desktop*\"",
    "test:e2e:windows": "npx playwright test --project=\"*Windows*\"",
    "test:e2e:macos": "npx playwright test --project=\"*macOS*\"",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report ./e2e/playwright-report",
    "test:e2e:update-snapshots": "npx playwright test --update-snapshots"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/schibsted-grotesk": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@gsap/react": "^2.1.2",
    "@mui/material": "^7.3.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@studio-freight/lenis": "^1.0.42",
    "@tailwindcss/vite": "^4.1.13",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.574.0",
    "motion": "^12.40.0",
    "react": "^19.1.1",
    "react-countup": "^6.5.3",
    "react-dom": "^19.1.1",
    "react-globe.gl": "^2.37.0",
    "react-intersection-observer": "^10.0.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.0",
    "react-slick": "^0.31.0",
    "react-toastify": "^11.0.5",
    "slick-carousel": "^1.8.1",
    "tailwindcss": "^4.1.13",
    "three": "^0.181.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/react-slick": "^0.23.13",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2"
  }
}
